  "symmetry": {
    "rules": {
      "SYM-01-loop-derived": "loop equals the ' -> '-joined Title-Case phase_order",
      "SYM-02-loop-acronym": "phase_order initials spell loop_name",
      "SYM-03-command-selector": "command.selector is 'phase', command.values equals phase_order, the command doc advertises --phase and documents no other selector",
      "SYM-04-registry-link": "discipline registry keys form a bijection with the 7 registries and each command names its stream or owner",
      "SYM-05-owner-naming": "registry owner slug ends in -registry",
      "SYM-06-gate-naming": "gate slug ends in -auditor",
      "SYM-07-auditor-suffix": "the -auditor skill-name suffix is reserved for class: auditor skills",
      "SYM-08-gate-topology": "discipline gates are exactly the 8 catalog auditors, each resident in its home discipline",
      "SYM-09-human-view": "registry human_view is memory/<key>/",
      "SYM-10-score-surface-typed": "every auditor declares a score_surface of type composite, diagnostic, or profiles-only",
      "SYM-11-score-surface-consistent": "score_surface agrees with the benchmark doc and framework-catalog composite/rollup policy",
      "SYM-12-grouping-title": "the skills.sh grouping title carries the loop_name, every framework id, the phase chain, and the skill count",
      "SYM-13-scope-edge": "every discipline command carries a Scope edge block",
      "SYM-14-command-h1": "a command H1 is '# <Title> Command' using the command stem or the discipline display_name",
      "SYM-15-metadata-keys": "SKILL.md metadata carries exactly author/version/discipline/phase/geo-relevance/hermes/openclaw",
      "SYM-16-deviation-hygiene": "every deviation names an implemented rule, resolves its scope, cites an existing source_doc, and still licenses a live violation",
      "SYM-17-auto-order": "the auto command resolver enumerates the seven discipline commands in logical_order"
    },
    "deviations": [
      {
        "id": "DEV-HUMANVIEW-LAUNCHES",
        "rule": "SYM-09-human-view",
        "scope": "registry:launches",
        "rationale": "memory/launch/<skill>/ is the launch discipline's working-notes namespace, and the dossier/calendar view predates v18 in end-user projects; renaming the human view would orphan user state.",
        "source_doc": "references/skill-contract.md",
        "since_version": "18.0.0"
      },
      {
        "id": "DEV-HUMANVIEW-NARRATIVE",
        "rule": "SYM-09-human-view",
        "scope": "registry:narrative",
        "rationale": "memory/narrative/<skill>/ is the narrative discipline's working-notes namespace, and canon.md/versions.md predate v18 in end-user projects; renaming the human view would orphan user state.",
        "source_doc": "references/skill-contract.md",
        "since_version": "18.0.0"
      }
    ]
  },
