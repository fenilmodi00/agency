# Fireworks AI
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Per-agent model paths (Fireworks format)
MODEL_DISCOVERY=accounts/fireworks/models/glm-5p2
MODEL_PROPOSAL=qwen3p7-plus
MODEL_OUTREACH=accounts/fireworks/models/glm-5p2
MODEL_NEGOTIATOR=deepseek-v4-pro
MODEL_CONTRACT=accounts/fireworks/models/glm-5p2

# Instagram credentials
IG_USERNAME=
IG_PASSWORD=
IG_SESSION_FILE=data/ig_session.json

# Scraper integration (SQLite path or HTTP API)
SCRAPER_DB_PATH=
SCRAPER_API_URL=

# Agents database path
AGENTS_DB_PATH=data/agents.db

# Safety thresholds
MAX_DMS_PER_DAY=20
DM_DELAY_SECONDS=5
DM_DELAY_JITTER=3
MAX_NEGOTIATION_ROUNDS=3
BUDGET_OVERRUN_PERCENT=120
MAX_PROFILE_FETCHES_PER_RUN=50

# Token budget
MAX_TOKENS_PER_AGENT=4000
MAX_TOTAL_TOKENS_PER_RUN=25000

# Logging
LOG_LEVEL=INFO